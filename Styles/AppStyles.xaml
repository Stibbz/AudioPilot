<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══ Title-bar buttons ══════════════════════════════════════════════════ -->

    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#3A3A3A" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CloseButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#C42B1C" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#363636" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Device card (main switcher) ═══════════════════════════════════════ -->

    <Style x:Key="DeviceCardButtonStyle" TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Card" Background="#333333" BorderBrush="#3A3A3A"
                            BorderThickness="1" CornerRadius="10" Padding="14,12">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Card" Property="Background" Value="#3A3A3A" />
                            <Setter TargetName="Card" Property="BorderBrush" Value="#3A3A3A" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Card" Property="Background" Value="#222222" />
                        </Trigger>
                        <!-- BT disconnected: subtle blue-dark tint -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsBluetooth}" Value="True" />
                                <Condition Binding="{Binding IsBluetoothConnected}" Value="False" />
                                <Condition Binding="{Binding IsConnecting}" Value="False" />
                                <Condition Binding="{Binding IsConnectionFailed}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="Card" Property="Background" Value="#292929" />
                            <Setter TargetName="Card" Property="BorderBrush" Value="#3A3A3A" />
                        </MultiDataTrigger>
                        <!-- Connecting: slightly dimmed -->
                        <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                            <Setter TargetName="Card" Property="Background" Value="#292929" />
                            <Setter TargetName="Card" Property="Opacity" Value="0.7" />
                        </DataTrigger>
                        <!-- Connection failed: red tint -->
                        <DataTrigger Binding="{Binding IsConnectionFailed}" Value="True">
                            <Setter TargetName="Card" Property="Background" Value="#261A1A" />
                            <Setter TargetName="Card" Property="BorderBrush" Value="#6B2020" />
                        </DataTrigger>
                        <!-- Active (default) device -->
                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                            <Setter TargetName="Card" Property="Background" Value="#292929" />
                            <Setter TargetName="Card" Property="BorderBrush" Value="#FF9068" />
                            <Setter TargetName="Card" Property="BorderThickness" Value="1.5" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Icon bubble background -->
    <Style x:Key="DeviceIconBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#3A3A3A" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsDefault}" Value="True">
                <Setter Property="Background" Value="#222222" />
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsBluetooth}" Value="True" />
                    <Condition Binding="{Binding IsBluetoothConnected}" Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="#3A3A3A" />
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Icon glyph colour -->
    <Style x:Key="DeviceIconTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#555555" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsDefault}" Value="True">
                <Setter Property="Foreground" Value="#FF9068" />
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsBluetooth}" Value="True" />
                    <Condition Binding="{Binding IsBluetoothConnected}" Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Foreground" Value="#555555" />
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Subtitle below device name -->
    <Style x:Key="DeviceSubtitleStyle" TargetType="TextBlock">
        <Setter Property="Text" Value="Playback Device" />
        <Setter Property="Foreground" Value="#555555" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsDefault}" Value="True">
                <Setter Property="Text" Value="Currently active" />
                <Setter Property="Foreground" Value="#FF9068" />
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsBluetooth}" Value="True" />
                    <Condition Binding="{Binding IsBluetoothConnected}" Value="True" />
                    <Condition Binding="{Binding IsDefault}" Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Text" Value="Bluetooth · Connected" />
                <Setter Property="Foreground" Value="#2ECC71" />
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsBluetooth}" Value="True" />
                    <Condition Binding="{Binding IsBluetoothConnected}" Value="False" />
                    <Condition Binding="{Binding IsConnecting}" Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Text" Value="Bluetooth · Click to connect" />
                <Setter Property="Foreground" Value="#666666" />
            </MultiDataTrigger>
            <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                <Setter Property="Text" Value="Connecting…" />
                <Setter Property="Foreground" Value="#888888" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsConnectionFailed}" Value="True">
                <Setter Property="Text" Value="Connection failed" />
                <Setter Property="Foreground" Value="#E05050" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ══ Settings device card ════════════════════════════════════════════════ -->

    <Style x:Key="SettingsCardButtonStyle" TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Card" Background="#333333" BorderBrush="#3A3A3A"
                            BorderThickness="1" CornerRadius="10" Padding="14,12">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Card" Property="Background" Value="#3A3A3A" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Card" Property="Background" Value="#222222" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                            <Setter TargetName="Card" Property="Background" Value="#292929" />
                            <Setter TargetName="Card" Property="BorderBrush" Value="#4A90D9" />
                            <Setter TargetName="Card" Property="BorderThickness" Value="1.5" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsIconBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#3A3A3A" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                <Setter Property="Background" Value="#3A3A3A" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SettingsIconTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#555555" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                <Setter Property="Foreground" Value="#4A90D9" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SettingsNameTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#888888" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                <Setter Property="Foreground" Value="#8D8B84" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SettingsCheckStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="Transparent" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                <Setter Property="Foreground" Value="#4A90D9" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ══ Hotkey badge button ═════════════════════════════════════════════════ -->
    <!--
        Shows the current key combo (e.g. "Ctrl+Alt+N") or "Not set".
        Set Tag="recording" from code-behind to display the amber capture state.
    -->
    <Style x:Key="HotkeyButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="#888888" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontFamily" Value="Consolas, Courier New" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="#292929" BorderBrush="#3A3A3A"
                            BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <TextBlock x:Name="Txt"
                                   Text="{TemplateBinding Content}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#363636" />
                            <Setter TargetName="Bg" Property="BorderBrush" Value="#555555" />
                        </Trigger>
                        <!-- Amber highlight while waiting for a key press -->
                        <Trigger Property="Tag" Value="recording">
                            <Setter TargetName="Bg" Property="Background" Value="#1A1200" />
                            <Setter TargetName="Bg" Property="BorderBrush" Value="#F59E0B" />
                            <Setter TargetName="Txt" Property="Foreground" Value="#F59E0B" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ Volume slider ════════════════════════════════════════════════════════ -->

    <Style x:Key="VolumeSliderStyle" TargetType="Slider">
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="1" />
        <Setter Property="SmallChange" Value="0.02" />
        <Setter Property="LargeChange" Value="0.1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center" Height="16">
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="#FF9068" Height="3" CornerRadius="1.5" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Focusable="False">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Width="11" Height="11" Fill="#FF9068">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Fill" Value="#FFB090" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="#3A3A3A" Height="3" CornerRadius="1.5" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
