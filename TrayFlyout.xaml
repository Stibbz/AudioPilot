<Window x:Class="SwitchAudioDevices.TrayFlyout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">

    <Border Background="#1C1C1C" CornerRadius="12" BorderBrush="#303030" BorderThickness="1" Padding="18,14"
            MouseLeftButtonUp="Border_MouseLeftButtonUp" Cursor="Hand">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="4" Opacity="0.65" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="8" />
        </Border.RenderTransform>

        <StackPanel MinWidth="220" MaxWidth="320">
            <TextBlock Text="CURRENT OUTPUT" FontSize="10" FontWeight="Bold"
                       Foreground="#555555" Margin="0,0,0,10" />

            <StackPanel Orientation="Horizontal">
                <Border Width="32" Height="32" Background="#1E3A5F" CornerRadius="8" Margin="0,0,12,0">
                    <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                               Foreground="#4A90D9" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="DeviceNameText" FontSize="14" FontWeight="Medium"
                           Foreground="#EBEBEB" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
