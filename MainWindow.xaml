<Window x:Class="SwitchAudioDevices.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio Switcher"
        Width="420"
        Height="Auto"
        MinHeight="320"
        MinWidth="360"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>


    <Border x:Name="RootBorder" Background="#1A1A1A" CornerRadius="12" BorderBrush="#2E2E2E" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="6" Opacity="0.6" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ══ TITLE BAR ════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="#4A90D9" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="Audio Switcher" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#E0E0E0" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="SettingsButton" Click="SettingsButton_Click" Width="32" Height="32"
                                ToolTip="Settings" Style="{StaticResource TitleBarButtonStyle}">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#888888" />
                        </Button>
                        <Button Click="CloseButton_Click" Width="32" Height="32"
                                ToolTip="Close" Style="{StaticResource CloseButtonStyle}">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#888888" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="0" Height="1" Background="#252525" VerticalAlignment="Bottom" />

            <!-- ══ CONTENT ═══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" x:Name="ContentContainer" ClipToBounds="True" MinHeight="120">

                <!-- PANEL A: Device List -->
                <Grid x:Name="DeviceListPanel">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="DeviceListTransform" />
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="20,14,16,6">
                        <TextBlock Text="OUTPUT DEVICES" FontSize="10" FontWeight="Bold"
                                   Foreground="#555555" VerticalAlignment="Center" />
                        <Button HorizontalAlignment="Right" Command="{Binding RefreshCommand}"
                                Width="30" Height="30" Cursor="Hand" ToolTip="Refresh"
                                Style="{StaticResource IconButtonStyle}">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#555555" />
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="16,0,16,0"
                                  MaxHeight="400">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Devices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,0,6"
                                                Command="{Binding DataContext.DeviceActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id}"
                                                Style="{StaticResource DeviceCardButtonStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Icon bubble -->
                                                <Border Width="36" Height="36" CornerRadius="8" VerticalAlignment="Center"
                                                        Style="{StaticResource DeviceIconBorderStyle}">
                                                    <TextBlock Text="{Binding DeviceIconGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Style="{StaticResource DeviceIconTextStyle}" />
                                                </Border>

                                                <!-- Name + subtitle -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                               Foreground="#EBEBEB" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock FontSize="11" Margin="0,2,0,0"
                                                               Style="{StaticResource DeviceSubtitleStyle}" />
                                                </StackPanel>

                                                <!-- ── Status badges ─────────────────────────────────────── -->
                                                <Grid Grid.Column="2" VerticalAlignment="Center">

                                                    <!-- Active (this device is the default output) -->
                                                    <Border CornerRadius="10" Padding="8,4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background"   Value="#1E3A5F" />
                                                                <Setter Property="BorderBrush"  Value="#4A90D9" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                                <Setter Property="Visibility"   Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="9" Foreground="#4A90D9"
                                                                       VerticalAlignment="Center" Margin="0,0,5,0" />
                                                            <TextBlock Text="Active" FontSize="11" FontWeight="SemiBold" Foreground="#4A90D9" />
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Connected (BT connected, not the default output) -->
                                                    <Border CornerRadius="10" Padding="8,4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background"      Value="#0D2A1A" />
                                                                <Setter Property="BorderBrush"     Value="#2ECC71" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                                <Setter Property="Visibility"      Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsBluetooth}"          Value="True" />
                                                                            <Condition Binding="{Binding IsBluetoothConnected}" Value="True" />
                                                                            <Condition Binding="{Binding IsDefault}"            Value="False" />
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE702;" FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="9" Foreground="#2ECC71"
                                                                       VerticalAlignment="Center" Margin="0,0,5,0" />
                                                            <TextBlock Text="Connected" FontSize="11" FontWeight="SemiBold" Foreground="#2ECC71" />
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Connect (BT paired but disconnected) -->
                                                    <Border CornerRadius="10" Padding="8,4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background"      Value="Transparent" />
                                                                <Setter Property="BorderBrush"     Value="#4A90D9" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                                <Setter Property="Visibility"      Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsBluetooth}"          Value="True" />
                                                                            <Condition Binding="{Binding IsBluetoothConnected}" Value="False" />
                                                                            <Condition Binding="{Binding IsConnecting}"         Value="False" />
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE702;" FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="9" Foreground="#4A90D9"
                                                                       VerticalAlignment="Center" Margin="0,0,5,0" />
                                                            <TextBlock Text="Connect" FontSize="11" FontWeight="SemiBold" Foreground="#4A90D9" />
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Connecting… (in progress) -->
                                                    <Border CornerRadius="10" Padding="8,4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background"      Value="#252525" />
                                                                <Setter Property="BorderBrush"     Value="#555555" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                                <Setter Property="Visibility"      Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="Connecting…" FontSize="11" FontWeight="SemiBold" Foreground="#888888" />
                                                    </Border>

                                                    <!-- Failed (connection timed out or rejected) -->
                                                    <Border CornerRadius="10" Padding="8,4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background"      Value="#2A0D0D" />
                                                                <Setter Property="BorderBrush"     Value="#C0392B" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                                <Setter Property="Visibility"      Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsConnectionFailed}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="9" Foreground="#E05050"
                                                                       VerticalAlignment="Center" Margin="0,0,5,0" />
                                                            <TextBlock Text="Failed" FontSize="11" FontWeight="SemiBold" Foreground="#E05050" />
                                                        </StackPanel>
                                                    </Border>

                                                </Grid>
                                                <!-- ── end badges ─── -->

                                                <!-- Volume slider - hidden for disconnected BT devices -->
                                                <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsBluetooth}" Value="True" />
                                                                        <Condition Binding="{Binding IsBluetoothConnected}" Value="False" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </MultiDataTrigger>
                                                                <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Slider Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Style="{StaticResource VolumeSliderStyle}" />
                                                </Border>

                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No devices selected.&#x0a;Open Settings to choose devices."
                                       TextAlignment="Center" FontSize="12" Foreground="#444444"
                                       Margin="0,24,0,0" LineHeight="20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Devices.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- PANEL B: Settings -->
                <Grid x:Name="SettingsPanel" Visibility="Collapsed">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="SettingsTransform" X="420" />
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="8,8,16,6">
                        <Button HorizontalAlignment="Left" Click="BackButton_Click"
                                Width="36" Height="36" Cursor="Hand" ToolTip="Back"
                                Style="{StaticResource IconButtonStyle}">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#888888" />
                        </Button>
                        <TextBlock Text="Settings" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#E0E0E0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Height="420"
                                  Padding="16,0,16,8">
                        <StackPanel>

                            <TextBlock Text="AUDIO DEVICES" FontSize="10" FontWeight="Bold"
                                       Foreground="#555555" Margin="4,8,0,8" />

                            <ItemsControl ItemsSource="{Binding SettingsDevices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,0,6"
                                                Command="{Binding DataContext.ToggleSettingsDeviceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id}"
                                                Style="{StaticResource SettingsCardButtonStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="36" Height="36" CornerRadius="8" VerticalAlignment="Center"
                                                        Style="{StaticResource SettingsIconBorderStyle}">
                                                    <TextBlock Text="{Binding DeviceIconGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Style="{StaticResource SettingsIconTextStyle}" />
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                                           FontWeight="Medium" VerticalAlignment="Center"
                                                           Margin="0,0,8,0" TextTrimming="CharacterEllipsis"
                                                           Style="{StaticResource SettingsNameTextStyle}" />
                                                <TextBlock Grid.Column="2" Text="&#xE73E;"
                                                           FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource SettingsCheckStyle}" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="GENERAL" FontSize="10" FontWeight="Bold"
                                       Foreground="#555555" Margin="4,16,0,8" />

                            <!-- Launch at startup -->
                            <Button Margin="0,0,0,6"
                                    Command="{Binding ToggleStartupCommand}"
                                    Style="{StaticResource SettingsCardButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="8" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2A2A2A" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LaunchAtStartup}" Value="True">
                                                        <Setter Property="Background" Value="#1E3A5F" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#555555" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LaunchAtStartup}" Value="True">
                                                            <Setter Property="Foreground" Value="#4A90D9" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="Launch at startup" FontSize="13" FontWeight="Medium" Foreground="#EBEBEB" />
                                        <TextBlock FontSize="11" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Disabled" />
                                                    <Setter Property="Foreground" Value="#555555" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LaunchAtStartup}" Value="True">
                                                            <Setter Property="Text" Value="Starts with Windows" />
                                                            <Setter Property="Foreground" Value="#4A90D9" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LaunchAtStartup}" Value="True">
                                                        <Setter Property="Foreground" Value="#4A90D9" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>

                            <TextBlock Text="HOTKEYS" FontSize="10" FontWeight="Bold"
                                       Foreground="#555555" Margin="4,16,0,8" />

                            <!-- Next device -->
                            <Border Background="#222222" BorderBrush="#2E2E2E" BorderThickness="1"
                                    CornerRadius="10" Padding="14,12" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="8" Background="#2A2A2A" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555555" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="Next device" FontSize="13" FontWeight="Medium" Foreground="#EBEBEB" />
                                        <TextBlock Text="Esc to cancel  ·  Del to clear"
                                                   FontSize="10" Foreground="#444444" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Button x:Name="HotkeyNextButton" Grid.Column="2"
                                            Content="{Binding HotkeyNextText}"
                                            Click="HotkeyNextButton_Click"
                                            Style="{StaticResource HotkeyButtonStyle}" />
                                </Grid>
                            </Border>

                            <!-- Previous device -->
                            <Border Background="#222222" BorderBrush="#2E2E2E" BorderThickness="1"
                                    CornerRadius="10" Padding="14,12" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" CornerRadius="8" Background="#2A2A2A" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE892;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555555" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="Previous device" FontSize="13" FontWeight="Medium" Foreground="#EBEBEB" />
                                        <TextBlock Text="Esc to cancel  ·  Del to clear"
                                                   FontSize="10" Foreground="#444444" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Button x:Name="HotkeyPrevButton" Grid.Column="2"
                                            Content="{Binding HotkeyPrevText}"
                                            Click="HotkeyPrevButton_Click"
                                            Style="{StaticResource HotkeyButtonStyle}" />
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ══ STATUS STRIP ═════════════════════════════════════════════════════ -->
            <!-- Collapses entirely when there is nothing to say. -->
            <Border Grid.Row="2" BorderBrush="#252525" BorderThickness="0,1,0,0"
                    Padding="20,8" CornerRadius="0,0,12,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasStatus}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock FontSize="11" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Text="{Binding StatusMessage}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#888888" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                                    <Setter Property="Foreground" Value="#E05050" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</Window>
